# NewAPI Middleware Tool - Environment Configuration
#
# 推荐使用 deploy.sh 自动生成此文件
# 手动配置时，复制此文件为 .env 并修改

# ===========================================
# NewAPI 环境 (由 deploy.sh 自动检测)
# ===========================================

# NewAPI 容器名
NEWAPI_CONTAINER=new-api

# NewAPI Docker 网络名
NEWAPI_NETWORK=

# ===========================================
# 数据库配置 (由 deploy.sh 自动检测)
# ===========================================

# Go 版本推荐使用完整 DSN 字符串
# SQL_DSN：业务数据库（newapi 主业务库，保留业务数据读取）
# TOOLS_SQL_DSN：tools 配置数据库（未设置时会自动回退到 SQL_DSN）
# MySQL 示例：user:pass@tcp(host:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local
# PgSQL 示例：host=localhost port=5432 user=postgres password=xxx dbname=one-api sslmode=disable
# 推荐示例：SQL_DSN 保持业务库语义，TOOLS_SQL_DSN 指向 tools 配置库
SQL_DSN=newapi:your_business_db_password@tcp(10.10.10.50:3306)/newapi?charset=utf8mb4&parseTime=True&loc=Local
TOOLS_SQL_DSN=newapitools:HGmerm6WHysnDifb@tcp(10.10.10.50:3306)/newapitools?charset=utf8mb4&parseTime=True&loc=Local

# 兼容旧版分离配置（仅用于 SQL_DSN 未设置时拼装业务库 DSN）
# 数据库引擎: mysql 或 postgres
DB_ENGINE=mysql

# 数据库主机 (容器名或服务名)
DB_DNS=1Panel-mysql-c3xP

# 数据库端口 (MySQL: 3306, PostgreSQL: 5432)
DB_PORT=3306

# 业务数据库名
DB_NAME=newapi

# 业务数据库用户
DB_USER=newapi

# 业务数据库密码
DB_PASSWORD=HGmerm6WHysnDifb

# ===========================================
# 认证配置
# ===========================================

# 前端访问密码 (必填)
ADMIN_PASSWORD=

# 后端 API Key (必填，deploy.sh 会自动生成)
API_KEY=

# JWT 密钥 (deploy.sh 会自动生成)
JWT_SECRET=

# JWT 过期时间 (小时)
JWT_EXPIRE_HOURS=24

# ===========================================
# 服务配置
# ===========================================

# 前端端口 (默认: 1145)
FRONTEND_PORT=1145

# 时区
TIMEZONE=Asia/Shanghai

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ===========================================
# 外部服务
# ===========================================

# NewAPI 内部地址 (用于API调用)
NEWAPI_BASEURL=

# ===========================================
# Redis 缓存配置
# ===========================================
# Redis 已默认启用，用于加速缓存恢复和查询性能
# 推荐直接使用完整连接串
REDIS_CONN_STRING=redis://:RKcfc3N44yxmA2Ph@10.10.10.50:6379

# Redis 密码 (无密码则留空)
REDIS_PASSWORD=
